profiles {

    standard {
        process.executor = 'local'
        conda.enabled = true
        process {
            withLabel: utils{
                conda = './utils_env.yaml'
            }
        }
    }

    debug {
        process.executor = 'local'
        conda.enabled = true
        process {
            withLabel: utils{
                conda = './utils_env.yaml'
            }
        }
        timeline {
            enabled = true
            file = "timeline.html"
            overwrite = true
        }
        report {
            enabled = true
            file = "report.html"
            overwrite = true
        }
        trace {
            enabled = true
            file = "trace.txt"
            overwrite = true
        }
    }
}

params {
    outdir = "."
    species = null
    track = null
}

